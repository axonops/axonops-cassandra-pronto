{
  "_comment": "Creates an AMI for Apache Cassandra.",

  "variables": {
    "aws_profile": "{{env `AWS_PROFILE`}}",
    "aws_region": "{{env `AWS_REGION`}}",
    "vpc_region": "{{env `VPC_REGION`}}",
    "packer_sg_id": "{{env `PACKER_SG_ID`}}",
    "packer_subnet_id": "{{env `PACKER_SUBNET_ID`}}",
    "packer_vpc_id": "{{env `PACKER_VPC_ID`}}",
    "base_ami_id": "{{env `BASE_AMI_ID`}}",
    "base_ami_name" : "{{env `BASE_AMI_NAME`}}",
    "packer_cassandra_version": "{{env `PACKER_CASSANDRA_VER`}}",
    "cassandra_semver": "{{env `PACKER_CASSANDRA_SEMVER`}}",
    "packer_iam_profile": "{{env `PACKER_ROLE`}}",
    "packer_env": "{{env `PACKER_ENVIRONMENT`}}",
    "config_path": "{{env `PACKER_CONFIG_PATH`}}"
  },
  "builders": [
    {
      "type": "amazon-ebs",
      "name": "Apache Cassandra AMI",
      "ami_description": "Apache Cassandra AMI",
      "ami_name": "cassandra-{{ user `packer_cassandra_version` }}-{{timestamp}}",
      "profile": "{{user `aws_profile`}}",
      "region": "{{user `aws_region`}}",
      "ami_regions": ["{{user `vpc_region` }}"],

      "instance_type": "m5.large",
      "security_group_id": "{{user `packer_sg_id`}}",
      "subnet_id": "{{user `packer_subnet_id`}}",
      "vpc_id": "{{user `packer_vpc_id`}}",
      "iam_instance_profile": "{{user `packer_iam_profile`}}",
      "source_ami": "{{user `base_ami_id`}}",
      "source_ami_filter": {
        "filters": {
          "name": "al2023-ami-*-x86_64",
          "root-device-type": "ebs",
          "virtualization-type": "hvm"
        },
        "owners": ["amazon"],
        "most_recent": true
      },

      "associate_public_ip_address": true,
      "ena_support": true,
      "ssh_interface": "public_ip",
      "ssh_username": "ec2-user",

      "ami_block_device_mappings": [
        {
          "delete_on_termination": true,
          "device_name": "/dev/xvda",
          "volume_size": 100,
          "volume_type": "gp2"
        }
      ],
      "run_tags": {
        "Name": "Packer Builder (Apache Cassandra)"
      },
      "tags": {
        "CreationTime": "{{isotime \"01022006-150405\"}}",
        "Name": "cassandra-{{user `packer_cassandra_version`}}",
        "cassandra-version" : "{{user `packer_cassandra_version`}}",
        "base-ami-id" :  "{{user `base_ami_id`}}",
        "base-ami-name" :  "{{user `base_ami_name`}}",
        "status": "available"
      }
    }
  ],
  "provisioners": [
    {
      "type": "shell",
      "inline": [
        "sudo yum update -y",
        "sudo yum install -y bind-utils dnsmasq jq libaio lvm2 nc telnet wget"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "cd /tmp",
        "curl -s https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip -o awscliv2.zip",
        "unzip -qq awscliv2.zip",
        "mkdir -p /home/ec2-user/.local/aws",
        "./aws/install -i /home/ec2-user/.local/aws -b /home/ec2-user/.local/bin",
        "sudo rm -rf awscliv2.zip ./aws"
      ]
    },
    {
      "type": "file",
      "source": "./include",
      "destination": "/tmp"
    },
    {
      "type": "shell",
      "inline": [
        "sudo yum install -y python3 python3-pip python3-botocore python3-boto3 git tar gzip gettext",
        "curl -sL https://github.com/helmfile/vals/releases/download/v0.44.3/vals_0.44.3_linux_amd64.tar.gz | tar xz -C /tmp",
        "sudo mv /tmp/vals /usr/local/bin/vals",
        "mkdir /home/ec2-user/.pip/",
        "sudo mv /tmp/include/pip.conf /home/ec2-user/.pip/pip.conf",
        "python3 -m pip install --user --upgrade awsretry",
        "sudo python3 -m pip install --user --upgrade awsretry"
      ]
    },
    {
      "type": "file",
      "source": "./ansible",
      "destination": "/tmp"
    },
    {
      "type": "shell",
      "inline": [
        "sudo curl -L https://github.com/mikefarah/yq/releases/download/v4.53.3/yq_linux_amd64 -o /usr/local/bin/yq",
        "sudo chmod +x /usr/local/bin/yq",
        "sudo python3 -m venv /opt/ansible-venv",
        "sudo /opt/ansible-venv/bin/pip install --upgrade pip",
        "sudo /opt/ansible-venv/bin/pip install 'ansible-core==2.15.*'",
        "sudo mkdir -p /opt/tmp",
        "sudo chmod 1777 /opt/tmp",
        "sudo /opt/ansible-venv/bin/ansible-galaxy collection install -r /tmp/ansible/requirements.yml"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "sudo /opt/ansible-venv/bin/ansible-playbook /tmp/ansible/bake-cassandra.yml --connection=local -i localhost, --extra-vars \"ansible_python_interpreter=/opt/ansible-venv/bin/python3 ansible_remote_tmp=/opt/tmp ansible_local_tmp=/opt/tmp cassandra_full_version={{user `cassandra_semver`}}\""
      ]
    },
    {
      "type": "shell",
      "inline": [
        "sudo rm -rf /tmp/ansible /opt/ansible-venv /opt/tmp /root/.ansible"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "sudo mv /tmp/include/limits.conf /etc/security/limits.conf",
        "sudo mv /tmp/include/sysctl.conf /etc/sysctl.conf",
        "sudo mv /tmp/include/ntp.conf /etc/ntp.conf",
        "sudo mv /tmp/include/trusted.conf /etc/dnsmasq.d/trusted.conf",
        "sudo chmod +x /tmp/include/update_auditd.sh",
        "sudo /tmp/include/update_auditd.sh",
        "sudo rm -rf /tmp/include"
      ]
    },
    {
      "type": "file",
      "source": "./scripts",
      "destination": "/tmp"
    },
    {
      "type": "file",
      "source": "{{user `config_path`}}/cassandra/gen_ca_cert.conf",
      "destination": "/tmp/scripts/gen_ca_cert.conf"
    },
    {
      "type": "file",
      "source": "{{user `config_path`}}/cassandra/configs/{{user `packer_cassandra_version`}}/cassandra-{{user `packer_cassandra_version`}}.yaml",
      "destination": "/tmp/scripts/cassandra.yaml.tmpl"
    },
    {
      "type": "shell",
      "inline": [
        "sudo mkdir -p /opt/cassandra",
        "sudo mv /tmp/scripts /opt/cassandra/",
        "sudo chown -R cassandra:cassandra /opt",
        "sudo chmod -R a+r /opt/",
        "sudo chmod -R a+rx /opt/cassandra/scripts",
        "sudo chown -R cassandra:cassandra /etc/cassandra",
        "sudo chmod -R a+r /etc/cassandra/"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "sudo rm -f /home/ec2-user/.ssh/authorized_keys"
      ]
    }
  ]
}
